# FRONTIER Environment Variables Template
# Copy to .env and fill with your actual values
# DO NOT commit actual secrets to git

# ============= DATABASE =============
DATABASE_URL=postgresql://user:password@localhost:5432/frontier

# ============= SESSION =============
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-secure-random-string-min-32-chars

# ============= ALGORAND BLOCKCHAIN =============
# Network: "mainnet" or "testnet"
ALGORAND_NETWORK=testnet

# Admin mnemonic (25-word phrase) - STORE IN SECURE VAULT, NEVER IN CODE
# This account performs on-chain operations (ASA creation, transfers, etc.)
ALGORAND_ADMIN_MNEMONIC=word1 word2 word3 ... word25

# Algorand RPC endpoints (optional, defaults to testnet)
ALGOD_URL=https://testnet-api.algonode.cloud
INDEXER_URL=https://testnet-idx.algonode.cloud

# ============= REDIS (Upstash) =============
# For world events, game state caching, and session storage
UPSTASH_REDIS_REST_URL=https://your-instance-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-api-token

# ============= FRONTEND =============
# URL of the client app (for CORS)
CLIENT_ORIGIN=http://localhost:3000

# Public base URL for generated content (NFT metadata, static assets)
PUBLIC_BASE_URL=http://localhost:5000

# ============= DEPLOYMENT =============
NODE_ENV=development

# ============= OPTIONAL FEATURES =============
# AI_ENABLED: "true" to enable AI faction turns, "false" or unset to disable
AI_ENABLED=false

# FORCE_NEW_ASA: "true" to create a new Algorand Standard Asset on startup
FORCE_NEW_ASA=false

# ============= NOTES =============
# Production Checklist:
# - Change ALGORAND_NETWORK from "testnet" to "mainnet"
# - Rotate SESSION_SECRET (don't reuse testnet value)
# - Update ALGORAND_ADMIN_MNEMONIC with production key
# - Set NODE_ENV=production (suppresses console logs)
# - Update CLIENT_ORIGIN to production domain
# - Update PUBLIC_BASE_URL to production domain
# - Verify UPSTASH_REDIS credentials for production instance
